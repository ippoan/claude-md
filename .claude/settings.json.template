{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Skill",
      "Read",
      "Edit",
      "Write",
      "ToolSearch",
      "AskUserQuestion",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(pwd)",
      "Bash(which:*)",
      "Bash(env)",
      "Bash(env:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(chmod:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(ln:*)",
      "Bash(python3:*)",
      "Bash(curl:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-remote:*)",
      "Bash(git config --get:*)",
      "Bash(bash:*)",
      "Bash(ss:*)",
      "mcp__github__issue_read",
      "mcp__github__pull_request_read",
      "mcp__github__get_file_contents",
      "mcp__github__list_releases",
      "mcp__github__get_release_by_tag",
      "mcp__github__list_commits",
      "mcp__github__list_branches",
      "mcp__github__list_pull_requests",
      "mcp__github__list_issues",
      "mcp__github__search_code",
      "mcp__github__search_issues",
      "mcp__github__search_pull_requests",
      "mcp__github__add_issue_comment",
      "mcp__github__subscribe_pr_activity",
      "mcp__github__unsubscribe_pr_activity"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/root/.claude/hooks/session-start-install-hooks.sh",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
